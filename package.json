{
  "name": "noveltea",
  "version": "0.1.0",
  "private": true,
  "description": "Structured authoring environment for novels and narrative worlds — part of the Avosos ecosystem",
  "author": "Avosos",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3300",
    "dev:electron": "concurrently --kill-others \"next dev --port 3300\" \"wait-on http://localhost:3300 && cross-env ELECTRON_DEV_URL=http://localhost:3300 electron .\"",
    "build": "next build",
    "start": "electron .",
    "dist": "next build && electron-builder",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.11",
    "lucide-react": "^0.577.0",
    "uuid": "^13.0.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.avosos.noveltea",
    "productName": "NovelTea",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
